{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "psico-conecta",
  "main": "../infraestructura/cloudflare/worker.js",
  "compatibility_date": "2026-06-03",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/posthog/*"]
  }
}
