{
  "family": "psicoconecta-usuarios",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [{
    "name": "usuarios",
    "image": "ACCOUNT_ID.dkr.ecr.us-east-2.amazonaws.com/psicoconecta/usuarios:latest",
    "essential": true,
    "command": ["sh", "-c", "python app/preparar_bd.py && python app/datos_iniciales.py && exec python app/ejecutar.py"],
    "portMappings": [{"name": "usuarios", "containerPort": 5001, "protocol": "tcp"}],
    "environment": [
      {"name": "PORT", "value": "5001"},
      {"name": "FLASK_ENV", "value": "production"},
      {"name": "MODO_DESARROLLO", "value": "false"},
      {"name": "DATABASE_SCHEMA", "value": "usuarios_schema"},
      {"name": "FRONTEND_URL", "value": "https://d1wkhs3cq8vcom.cloudfront.net"},
      {"name": "CORS_ORIGINS", "value": "https://d1wkhs3cq8vcom.cloudfront.net"},
      {"name": "GOOGLE_LOGIN_CLIENT_ID", "value": "339658076678-kah0e205d5asf6ufnlh009lh5i4g8u70.apps.googleusercontent.com"},
      {"name": "AWS_REGION", "value": "us-east-2"}
    ],
    "secrets": [
      {"name": "DATABASE_URL", "valueFrom": "psicoconecta/DATABASE_URL"},
      {"name": "SECRET_KEY", "valueFrom": "psicoconecta/SECRET_KEY"},
      {"name": "JWT_SECRET_KEY", "valueFrom": "psicoconecta/JWT_SECRET_KEY"}
    ],
    "logConfiguration": {"logDriver": "awslogs", "options": {"awslogs-group": "/ecs/psicoconecta-usuarios", "awslogs-region": "us-east-2", "awslogs-stream-prefix": "ecs"}}
  }]
}
