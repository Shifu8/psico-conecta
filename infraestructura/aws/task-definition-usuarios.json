{
  "family": "psicoconecta-usuarios",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::060899556466:role/ecsTaskExecutionRole",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "usuarios",
      "image": "060899556466.dkr.ecr.us-east-2.amazonaws.com/psicoconecta/usuarios:latest",
      "essential": true,
      "command": ["sh", "-c", "python app/datos_iniciales.py && exec python app/ejecutar.py"],
      "portMappings": [{"containerPort": 5001, "protocol": "tcp"}],
      "environment": [
        {"name": "PORT", "value": "5001"},
        {"name": "FLASK_ENV", "value": "production"},
        {"name": "MODO_DESARROLLO", "value": "false"},
        {"name": "FRONTEND_URL", "value": "https://psico-conecta.brandon-medina.workers.dev"},
        {"name": "CORS_ORIGINS", "value": "https://psico-conecta.brandon-medina.workers.dev,https://d1wkhs3cq8vcom.cloudfront.net,http://psicoconecta-frontend-060899556466.s3-website.us-east-2.amazonaws.com"},
        {"name": "COGNITO_ENABLED", "value": "false"},
        {"name": "GOOGLE_LOGIN_CLIENT_ID", "value": "339658076678-kah0e205d5asf6ufnlh009lh5i4g8u70.apps.googleusercontent.com"},
        {"name": "AWS_REGION", "value": "us-east-2"},
        {"name": "DATABASE_SCHEMA", "value": "usuarios_schema"}
      ],
      "secrets": [
        {"name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-2:060899556466:secret:psicoconecta/DATABASE_URL"},
        {"name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:060899556466:secret:psicoconecta/SECRET_KEY"},
        {"name": "JWT_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:060899556466:secret:psicoconecta/JWT_SECRET_KEY"},
        {"name": "GOOGLE_CLIENT_ID", "valueFrom": "arn:aws:secretsmanager:us-east-2:060899556466:secret:psicoconecta/GOOGLE_CLIENT_ID"},
        {"name": "GOOGLE_CLIENT_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-2:060899556466:secret:psicoconecta/GOOGLE_CLIENT_SECRET"},
        {"name": "GOOGLE_REFRESH_TOKEN", "valueFrom": "arn:aws:secretsmanager:us-east-2:060899556466:secret:psicoconecta/GOOGLE_REFRESH_TOKEN"},
        {"name": "GOOGLE_SENDER_EMAIL", "valueFrom": "arn:aws:secretsmanager:us-east-2:060899556466:secret:psicoconecta/GOOGLE_SENDER_EMAIL"},
        {"name": "TURNSTILE_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:060899556466:secret:psicoconecta/TURNSTILE_SECRET_KEY"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/psicoconecta-usuarios",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}


