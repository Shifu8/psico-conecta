{
  "family": "psicoconecta-usuarios",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "usuarios",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-2.amazonaws.com/psicoconecta/usuarios:latest",
      "essential": true,
      "command": ["sh", "-c", "python app/datos_iniciales.py && exec python app/ejecutar.py"],
      "portMappings": [{"containerPort": 5001, "protocol": "tcp"}],
      "environment": [
        {"name": "PORT", "value": "5001"},
        {"name": "FLASK_ENV", "value": "production"},
        {"name": "MODO_DESARROLLO", "value": "true"},
        {"name": "DATABASE_URL", "value": "sqlite:////tmp/datos.db"},
        {"name": "FRONTEND_URL", "value": "http://psicoconecta-frontend-060899556466.s3-website.us-east-2.amazonaws.com"},
        {"name": "CORS_ORIGINS", "value": "http://psicoconecta-frontend-060899556466.s3-website.us-east-2.amazonaws.com"},
        {"name": "COGNITO_ENABLED", "value": "false"},
        {"name": "GOOGLE_LOGIN_CLIENT_ID", "value": "339658076678-kah0e205d5asf6ufnlh009lh5i4g8u70.apps.googleusercontent.com"},
        {"name": "AWS_REGION", "value": "us-east-2"},
        {"name": "DATABASE_SCHEMA", "value": ""}
      ],
      "secrets": [
        {"name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:ACCOUNT_ID:secret:psicoconecta/SECRET_KEY"},
        {"name": "JWT_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:ACCOUNT_ID:secret:psicoconecta/JWT_SECRET_KEY"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/psicoconecta-usuarios",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
