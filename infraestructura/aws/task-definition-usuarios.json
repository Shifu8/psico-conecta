{
  "family": "psicoconecta-usuarios",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "usuarios",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-2.amazonaws.com/psicoconecta/usuarios:latest",
      "essential": true,
      "portMappings": [{"containerPort": 5001, "protocol": "tcp"}],
      "environment": [
        {"name": "PORT", "value": "5001"},
        {"name": "FLASK_ENV", "value": "production"},
        {"name": "MODO_DESARROLLO", "value": "true"},
        {"name": "DATABASE_URL", "value": "sqlite:///data/datos.db"},
        {"name": "FRONTEND_URL", "value": "http://localhost:5173"},
        {"name": "CORS_ORIGINS", "value": "*"}
      ],
      "secrets": [
        {"name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:ACCOUNT_ID:secret:psicoconecta/SECRET_KEY"},
        {"name": "JWT_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:ACCOUNT_ID:secret:psicoconecta/JWT_SECRET_KEY"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/psicoconecta-usuarios",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
