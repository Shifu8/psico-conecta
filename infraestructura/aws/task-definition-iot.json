{
  "family": "psicoconecta-iot",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "iot",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-2.amazonaws.com/psicoconecta/iot:latest",
      "essential": true,
      "portMappings": [{"containerPort": 5005, "protocol": "tcp"}],
      "environment": [
        {"name": "PORT", "value": "5005"},
        {"name": "AWS_REGION", "value": "us-east-2"},
        {"name": "DYNAMODB_TABLE_EMOCIONES", "value": "emociones"},
        {"name": "DYNAMODB_TABLE_LECTURAS", "value": "lecturas_iot"},
        {"name": "DYNAMODB_TABLE_NOTIFICACIONES", "value": "notificaciones"},
        {"name": "DYNAMODB_TABLE_LOGS", "value": "logs_iot"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/psicoconecta-iot",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
