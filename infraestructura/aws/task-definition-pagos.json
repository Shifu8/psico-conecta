{
  "family": "psicoconecta-pagos",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::108631844312:role/ecsTaskExecutionRole",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "pagos",
      "image": "108631844312.dkr.ecr.us-east-2.amazonaws.com/psicoconecta/pagos:latest",
      "essential": true,
      "portMappings": [{"name": "pagos", "containerPort": 5004, "protocol": "tcp"}],
      "environment": [
        {"name": "PORT", "value": "5004"},
        {"name": "FLASK_ENV", "value": "production"},
        {"name": "DB_SCHEMA", "value": "pagos_schema"},
        {"name": "DATABASE_SCHEMA", "value": "pagos_schema"},
        {"name": "TIMEZONE", "value": "America/Guayaquil"},
        {"name": "FRONTEND_URL", "value": "https://psico-conecta.brandon-medina.workers.dev"},
        {"name": "CORS_ORIGINS", "value": "https://psico-conecta.brandon-medina.workers.dev,https://d1wkhs3cq8vcom.cloudfront.net,http://psicoconecta-frontend-108631844312.s3-website.us-east-2.amazonaws.com"},
        {"name": "USERS_SERVICE_URL", "value": "http://usuarios:5001"},
        {"name": "CITAS_SERVICE_URL", "value": "http://citas:5002"},
        {"name": "VALIDAR_USUARIO_REMOTO", "value": "false"},
        {"name": "DEFAULT_CONSULTATION_PRICE_CENTS", "value": "3000"},
        {"name": "DEFAULT_CURRENCY", "value": "USD"},
        {"name": "REQUIRE_PAYMENT_FOR_TELECONSULTA", "value": "false"}
      ],
      "secrets": [
        {"name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-2:108631844312:secret:psicoconecta/DATABASE_URL"},
        {"name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:108631844312:secret:psicoconecta/SECRET_KEY"},
        {"name": "JWT_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:108631844312:secret:psicoconecta/JWT_SECRET_KEY"},
        {"name": "PAGOS_INTERNAL_TOKEN", "valueFrom": "arn:aws:secretsmanager:us-east-2:108631844312:secret:psicoconecta/PAGOS_INTERNAL_TOKEN"},
        {"name": "STRIPE_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:108631844312:secret:psicoconecta/STRIPE_SECRET_KEY"},
        {"name": "STRIPE_WEBHOOK_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-2:108631844312:secret:psicoconecta/STRIPE_WEBHOOK_SECRET"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/psicoconecta-pagos",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}


